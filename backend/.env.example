APP_NAME=FastAPI
APP_URL=http://localhost:8000
APP_ENV=local
APP_SECRET=
APP_DEBUG=true

DB_CONNECTION=postgresql+psycopg://username:password@localhost:5432/mydb

AUTH_ENABLED=false
RATE_LIMIT_ENABLED=false
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRY=3600
AUTH_REFRESH_TOKEN_EXPIRY=1296000
AUTH_PASSWORD_RESET_EXPIRY=600

ALLOW_ORIGINS=http://localhost:3000
ALLOW_CREDENTIALS=true
ALLOW_METHODS=*
ALLOW_HEADERS=*

EMAIL_HOST=localhost
EMAIL_PORT=8025
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TLS=false
EMAIL_FROM_ADDRESS=info@example.org
EMAIL_FROM_NAME="FastAPI App"

TEMPLATE_PATH=./src/templates

FRONTEND_URL=http://localhost:3000
FRONTEND_PASSWORD_RESET_PATH=reset-password?token=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_SUCCESS_URL="http://localhost:5173/billing/success"
BILLING_CANCEL_URL="http://localhost:5173/billing/cancel"
BILLING_PORTAL_RETURN_URL="http://localhost:5173/settings/billing"
BILLING_AUTOMATIC_TAX=true
BILLING_TRIAL_PERIOD_DAYS=14
